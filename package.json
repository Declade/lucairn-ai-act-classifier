{
  "name": "@lucairn/ai-act-classifier",
  "version": "0.1.0",
  "description": "Free CLI that maps EU AI Act articles to your AI use case",
  "license": "MIT",
  "author": "Declade",
  "homepage": "https://lucairn.eu/tools/ai-act-classifier",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Declade/lucairn-ai-act-classifier.git"
  },
  "bugs": {
    "url": "https://github.com/Declade/lucairn-ai-act-classifier/issues"
  },
  "keywords": [
    "eu-ai-act",
    "ai-act",
    "compliance",
    "classifier",
    "regulation",
    "annex-iii",
    "annex-iv",
    "gpai",
    "high-risk",
    "lucairn"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "ai-act-classify": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "README.de.md",
    "LICENSE",
    "DATASET-LICENSE",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "pnpm run clean && tsc && cp -R src/data dist/data && mkdir -p dist/i18n && cp src/i18n/*.json dist/i18n/ && chmod +x dist/cli.js",
    "prepack": "pnpm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "typecheck:test": "tsc -p tsconfig.test.json --noEmit",
    "sync:three-category": "node --import tsx scripts/sync-three-category.ts",
    "sync:three-category:check": "node --import tsx scripts/sync-three-category.ts --check"
  },
  "dependencies": {
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "kleur": "^4.1.5"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsx": "^4.22.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=18.17"
  },
  "packageManager": "pnpm@10.30.3",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "private": false
}
